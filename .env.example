PROJECT_NAME=encodr
API_PORT=8000
UI_PORT=5173
POSTGRES_DB=encodr
POSTGRES_USER=encodr
POSTGRES_PASSWORD=encodr-dev-password
POSTGRES_PORT=5432
REDIS_PORT=6379
ENCODR_ENV=production
ENCODR_LOG_LEVEL=INFO
ENCODR_DATA_DIR=/data
ENCODR_TEMP_HOST_PATH=/temp
ENCODR_MEDIA_HOST_PATH=/media
ENCODR_AUTH_SECRET=change-me-before-production
ENCODR_WORKER_REGISTRATION_SECRET=change-me-before-production

# Optional UI/agent development helpers
ENCODR_WORKER_AGENT_API_BASE_URL=http://localhost:8000/api
ENCODR_WORKER_AGENT_KEY=worker-remote
ENCODR_WORKER_AGENT_DISPLAY_NAME=Remote Worker
ENCODR_WORKER_AGENT_TOKEN_FILE=.runtime/worker-agent.token
ENCODR_WORKER_AGENT_HEARTBEAT_INTERVAL_SECONDS=60
