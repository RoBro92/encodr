#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI_VENV_PYTHON="${ROOT_DIR}/.runtime/cli-venv/bin/python"

if [[ -x "${CLI_VENV_PYTHON}" ]]; then
  exec "${CLI_VENV_PYTHON}" "${ROOT_DIR}/encodr_cli.py" "$@"
fi

exec python3 "${ROOT_DIR}/encodr_cli.py" "$@"
